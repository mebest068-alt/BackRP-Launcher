{
  "name": "backrp-launcher",
  "version": "1.0.0",
  "description": "Официальный лаунчер BackRP для SA:MP",
  "author": "BackRP",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "pack": "electron-builder --win --dir"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ru.backrp.launcher",
    "productName": "BackRP Launcher",
    "copyright": "Copyright © BackRP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BackRP"
    },
    "publish": {
      "provider": "github",
      "owner": "mebest068-alt",
      "repo": "BackRP-Launcher"
    }
  }
}
